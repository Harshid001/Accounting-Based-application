generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  emailVerified   DateTime?
  password        String?
  name            String?
  role            UserRole       @default(CLIENT)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  clientId        String?
  isActive        Boolean        @default(true)
  authProvider    AuthProvider   @default(CREDENTIALS)
  image           String?
  phone           String?
  Comment         Comment[]
  Notification    Notification[]
  tasks           Task[]
  client          Client?        @relation("ClientUsers", fields: [clientId], references: [id], onDelete: Cascade)
  assignedClients Client[]       @relation("ClientAssignment")
}

model Client {
  id              String                @id @default(cuid())
  type            ClientType
  name            String
  email           String?               @unique
  phone           String?
  pan             String?
  gstin           String?
  tan             String?
  address         String?
  status          ClientStatus          @default(ACTIVE)
  createdAt       DateTime              @default(now())
  isPinned        Boolean               @default(false)
  Comment         Comment[]
  complianceItems ComplianceItem[]
  documents       Document[]
  invoices        Invoice[]
  services        ServiceSubscription[]
  tasks           Task[]
  clientUsers     User[]                @relation("ClientUsers")
  assignedTo      User[]                @relation("ClientAssignment")
}

model Service {
  id            String                @id @default(cuid())
  name          String                @unique
  subscriptions ServiceSubscription[]
}

model ServiceSubscription {
  id        String    @id @default(cuid())
  clientId  String
  serviceId String
  startDate        DateTime  @default(now())
  filingFrequency  String?   // e.g. "MONTHLY", "QUARTERLY", "ANNUALLY"
  invoices         Invoice[]
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service          Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ComplianceItem {
  id           String           @id @default(cuid())
  clientId     String
  type         ComplianceType
  status           ComplianceStatus @default(PENDING)
  dueDate          DateTime
  filedDate        DateTime?
  notes            String?
  manualOverride   Boolean          @default(true)
  Comment          Comment[]
  client       Client           @relation(fields: [clientId], references: [id])
  Notification Notification[]
  tasks        Task[]

  @@index([dueDate, status])
}

model Document {
  id               String       @id @default(cuid())
  clientId         String
  type             DocumentType
  fileKey          String
  fileName         String
  complianceItemId String?
  archived         Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  uploadedById     String
  Comment          Comment[]
  client           Client       @relation(fields: [clientId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  userId     String
  authMethod String?  // E.g., "SESSION", "API_KEY"
  ipAddress  String?
  diff       Json?
  createdAt  DateTime @default(now())
}

model Task {
  id               String          @id @default(cuid())
  clientId         String?
  complianceItemId String?
  title            String
  description      String?
  assignedToId     String?
  status           TaskStatus      @default(NOT_STARTED)
  dueDate          DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  Comment          Comment[]
  assignedTo       User?           @relation(fields: [assignedToId], references: [id])
  client           Client?         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  complianceItem   ComplianceItem? @relation(fields: [complianceItemId], references: [id], onDelete: Cascade)
}

model Notification {
  id                      String              @id @default(cuid())
  recipientId             String
  type                    NotificationType
  relatedComplianceItemId String?
  channel                 NotificationChannel
  triggerOffset           Int?
  sentAt                  DateTime?
  readAt                  DateTime?
  createdAt               DateTime            @default(now())
  recipient               User                @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  complianceItem          ComplianceItem?     @relation(fields: [relatedComplianceItemId], references: [id])

  @@unique([recipientId, relatedComplianceItemId, type, triggerOffset])
}

model InvoiceCounter {
  id  String @id
  seq Int    @default(0)
}

model Invoice {
  id                    String               @id @default(cuid())
  invoiceNumber         String               @unique
  clientId              String
  serviceSubscriptionId String?
  issueDate             DateTime             @default(now())
  dueDate               DateTime
  subtotal              Decimal              @db.Decimal(12, 2)
  taxTotal              Decimal              @db.Decimal(12, 2)
  total                 Decimal              @db.Decimal(12, 2)
  status                InvoiceStatus        @default(DRAFT)
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  Comment               Comment[]
  client                Client               @relation(fields: [clientId], references: [id])
  serviceSubscription   ServiceSubscription? @relation(fields: [serviceSubscriptionId], references: [id])
  lineItems             InvoiceLineItem[]
  payments              Payment[]
  paymentIntents        PaymentIntent[]

  @@index([issueDate])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @db.Decimal(5, 2)
  total       Decimal @db.Decimal(12, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String   @id @default(cuid())
  invoiceId      String
  amount         Decimal  @db.Decimal(12, 2)
  paymentDate    DateTime @default(now())
  method         String
  referenceId    String?
  createdAt      DateTime @default(now())
  gatewayEventId String?  @unique
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentDate])
}

model PaymentIntent {
  id        String   @id @default(cuid())
  invoiceId String
  orderId   String   @unique
  amount    Decimal  @db.Decimal(12, 2)
  status    String   @default("CREATED")
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Comment {
  id               String          @id @default(cuid())
  content          String
  authorId         String
  taskId           String?
  documentId       String?
  complianceItemId String?
  invoiceId        String?
  clientId         String?
  mentions         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  User             User            @relation(fields: [authorId], references: [id])
  Client           Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ComplianceItem   ComplianceItem? @relation(fields: [complianceItemId], references: [id], onDelete: Cascade)
  Document         Document?       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Invoice          Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  Task             Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([complianceItemId])
  @@index([documentId])
  @@index([invoiceId])
  @@index([taskId])
}

model StaffInvite {
  id              String    @id @default(cuid())
  email           String
  role            UserRole
  tokenHash       String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())

  @@index([tokenHash])
}

model RegistrationVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
}

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  DATA_ENTRY
  CLIENT
}

enum ClientType {
  INDIVIDUAL
  BUSINESS
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ONBOARDING
}

enum ComplianceType {
  GST
  INCOME_TAX
  SALES_TAX_VAT
  TDS
  ROC
}

enum ComplianceStatus {
  PENDING
  IN_PROGRESS
  FILED
  ACKNOWLEDGED
}

enum DocumentType {
  PURCHASE_INVOICE
  SALES_INVOICE
  BANK_STATEMENT
  TAX_DOCUMENT
  INCOME_PROOF
  EXPENSE_DOCUMENT
  AUDIT_DOCUMENT
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEW
  DONE
}

enum NotificationType {
  COMPLIANCE_DEADLINE
  TASK_ASSIGNED
  GENERAL
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}
